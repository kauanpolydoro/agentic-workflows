{
  "name": "@kauanpolydoro/agentic-workflows-core",
  "version": "0.3.0",
  "description": "Schemas, catalog parsing, manifests, path safety, and agent exporters for Agentic Workflows.",
  "license": "MIT",
  "keywords": [
    "agentic-workflows",
    "ai-agents",
    "schemas",
    "agent-exporters"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kauanpolydoro/agentic-workflows.git",
    "directory": "packages/core"
  },
  "homepage": "https://kauanpolydoro.github.io/agentic-workflows/",
  "bugs": {
    "url": "https://github.com/kauanpolydoro/agentic-workflows/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./adapter-registry": {
      "types": "./dist/adapter-registry.d.ts",
      "default": "./dist/adapter-registry.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsx ../../scripts/clean-package-dist.ts dist && tsc -p tsconfig.json && tsx ../../scripts/prepare-core-package.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json"
  },
  "dependencies": {
    "yaml": "2.9.0",
    "zod": "4.4.3"
  }
}
