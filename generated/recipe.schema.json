{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "number",
      "const": 4
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 4,
      "maxLength": 100
    },
    "summary": {
      "type": "string",
      "minLength": 20,
      "maxLength": 240
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*)?(?:\\+[0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*)?$"
    },
    "category": {
      "type": "string",
      "enum": [
        "api",
        "architecture",
        "code-review",
        "database",
        "debugging",
        "documentation",
        "maintenance",
        "migration",
        "operations",
        "performance",
        "refactoring",
        "release",
        "security",
        "testing"
      ]
    },
    "execution_mode": {
      "type": "string",
      "enum": ["supervised", "autonomous"]
    },
    "difficulty": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced"]
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "estimated_duration": {
      "type": "string",
      "pattern": "^[1-9]\\d*(?:m|h)$"
    },
    "tags": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      }
    },
    "inputs": {
      "type": "object",
      "properties": {
        "required": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "optional": {
          "minItems": 0,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "required": ["required", "optional"],
      "additionalProperties": false
    },
    "outputs": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "prerequisites": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "safety": {
      "type": "object",
      "properties": {
        "destructive": {
          "type": "boolean"
        },
        "requires_human_approval": {
          "minItems": 0,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "forbidden_actions": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "required": ["destructive", "requires_human_approval", "forbidden_actions"],
      "additionalProperties": false
    },
    "effects": {
      "type": "object",
      "properties": {
        "writes_code": {
          "type": "boolean"
        },
        "writes_configuration": {
          "type": "boolean"
        },
        "writes_documentation": {
          "type": "boolean"
        },
        "changes_dependencies": {
          "type": "boolean"
        },
        "changes_database": {
          "type": "boolean"
        },
        "changes_issue_tracker": {
          "type": "boolean"
        },
        "changes_production_traffic": {
          "type": "boolean"
        },
        "deletes_state": {
          "type": "boolean"
        },
        "publishes_artifacts": {
          "type": "boolean"
        }
      },
      "required": [
        "writes_code",
        "writes_configuration",
        "writes_documentation",
        "changes_dependencies",
        "changes_database",
        "changes_issue_tracker",
        "changes_production_traffic",
        "deletes_state",
        "publishes_artifacts"
      ],
      "additionalProperties": false
    },
    "agent_requirements": {
      "type": "object",
      "properties": {
        "capabilities": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "repository-read",
              "repository-write",
              "shell",
              "git",
              "github",
              "network",
              "browser",
              "test-execution",
              "database",
              "production-access",
              "persistent-execution",
              "subagent-orchestration",
              "distributed-coordination"
            ]
          }
        },
        "manual_invocation_required": {
          "type": "boolean",
          "const": true
        }
      },
      "required": ["capabilities", "manual_invocation_required"],
      "additionalProperties": false
    },
    "autonomy": {
      "type": "object",
      "properties": {
        "unattended_execution": {
          "type": "boolean",
          "const": true
        },
        "authorization": {
          "type": "string",
          "const": "upfront"
        },
        "mid_run_human_input": {
          "type": "string",
          "const": "not-required"
        },
        "user_stop_signal": {
          "type": "string",
          "const": "required"
        },
        "hard_deadline": {
          "type": "string",
          "const": "required"
        },
        "durable_checkpoints": {
          "type": "string",
          "const": "required"
        },
        "resume": {
          "type": "string",
          "const": "required"
        },
        "failure_policy": {
          "type": "string",
          "enum": ["fail-closed", "defer-and-continue"]
        }
      },
      "required": [
        "unattended_execution",
        "authorization",
        "mid_run_human_input",
        "user_stop_signal",
        "hard_deadline",
        "durable_checkpoints",
        "resume",
        "failure_policy"
      ],
      "additionalProperties": false
    },
    "output_contract": {
      "type": "object",
      "properties": {
        "schema": {
          "type": "string",
          "const": "output.schema.json"
        }
      },
      "required": ["schema"],
      "additionalProperties": false
    },
    "canonical": {
      "type": "object",
      "properties": {
        "file": {
          "type": "string",
          "const": "workflow.md"
        }
      },
      "required": ["file"],
      "additionalProperties": false
    },
    "agents": {
      "type": "object",
      "properties": {
        "generic": {
          "type": "object",
          "properties": {
            "bundle_compatibility": {
              "type": "string",
              "enum": ["compatible", "limited", "incompatible", "unknown"],
              "description": "Whether the recipe bundle can be serialized for this adapter without semantic loss."
            },
            "capability_status": {
              "type": "string",
              "enum": ["confirmed", "partial", "unknown", "missing", "not-applicable"],
              "description": "Evidence state for the external agent capabilities required to execute this recipe."
            },
            "limitations": {
              "minItems": 0,
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "description": "Recipe-specific serialization or external capability limitations."
            }
          },
          "required": ["bundle_compatibility", "capability_status", "limitations"],
          "additionalProperties": false
        },
        "claude-code": {
          "type": "object",
          "properties": {
            "bundle_compatibility": {
              "type": "string",
              "enum": ["compatible", "limited", "incompatible", "unknown"],
              "description": "Whether the recipe bundle can be serialized for this adapter without semantic loss."
            },
            "capability_status": {
              "type": "string",
              "enum": ["confirmed", "partial", "unknown", "missing", "not-applicable"],
              "description": "Evidence state for the external agent capabilities required to execute this recipe."
            },
            "limitations": {
              "minItems": 0,
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "description": "Recipe-specific serialization or external capability limitations."
            }
          },
          "required": ["bundle_compatibility", "capability_status", "limitations"],
          "additionalProperties": false
        },
        "codex": {
          "type": "object",
          "properties": {
            "bundle_compatibility": {
              "type": "string",
              "enum": ["compatible", "limited", "incompatible", "unknown"],
              "description": "Whether the recipe bundle can be serialized for this adapter without semantic loss."
            },
            "capability_status": {
              "type": "string",
              "enum": ["confirmed", "partial", "unknown", "missing", "not-applicable"],
              "description": "Evidence state for the external agent capabilities required to execute this recipe."
            },
            "limitations": {
              "minItems": 0,
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "description": "Recipe-specific serialization or external capability limitations."
            }
          },
          "required": ["bundle_compatibility", "capability_status", "limitations"],
          "additionalProperties": false
        },
        "cursor": {
          "type": "object",
          "properties": {
            "bundle_compatibility": {
              "type": "string",
              "enum": ["compatible", "limited", "incompatible", "unknown"],
              "description": "Whether the recipe bundle can be serialized for this adapter without semantic loss."
            },
            "capability_status": {
              "type": "string",
              "enum": ["confirmed", "partial", "unknown", "missing", "not-applicable"],
              "description": "Evidence state for the external agent capabilities required to execute this recipe."
            },
            "limitations": {
              "minItems": 0,
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "description": "Recipe-specific serialization or external capability limitations."
            }
          },
          "required": ["bundle_compatibility", "capability_status", "limitations"],
          "additionalProperties": false
        },
        "gemini-cli": {
          "type": "object",
          "properties": {
            "bundle_compatibility": {
              "type": "string",
              "enum": ["compatible", "limited", "incompatible", "unknown"],
              "description": "Whether the recipe bundle can be serialized for this adapter without semantic loss."
            },
            "capability_status": {
              "type": "string",
              "enum": ["confirmed", "partial", "unknown", "missing", "not-applicable"],
              "description": "Evidence state for the external agent capabilities required to execute this recipe."
            },
            "limitations": {
              "minItems": 0,
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "description": "Recipe-specific serialization or external capability limitations."
            }
          },
          "required": ["bundle_compatibility", "capability_status", "limitations"],
          "additionalProperties": false
        },
        "opencode": {
          "type": "object",
          "properties": {
            "bundle_compatibility": {
              "type": "string",
              "enum": ["compatible", "limited", "incompatible", "unknown"],
              "description": "Whether the recipe bundle can be serialized for this adapter without semantic loss."
            },
            "capability_status": {
              "type": "string",
              "enum": ["confirmed", "partial", "unknown", "missing", "not-applicable"],
              "description": "Evidence state for the external agent capabilities required to execute this recipe."
            },
            "limitations": {
              "minItems": 0,
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "description": "Recipe-specific serialization or external capability limitations."
            }
          },
          "required": ["bundle_compatibility", "capability_status", "limitations"],
          "additionalProperties": false
        }
      },
      "required": ["generic", "claude-code", "codex", "cursor", "gemini-cli", "opencode"],
      "additionalProperties": false
    },
    "verification": {
      "type": "object",
      "properties": {
        "structural": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "const": "derived"
            }
          },
          "required": ["status"],
          "additionalProperties": false
        },
        "installation": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": ["untested", "not-applicable"]
            }
          },
          "required": ["status"],
          "additionalProperties": false
        },
        "execution": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": ["untested", "not-applicable"]
            }
          },
          "required": ["status"],
          "additionalProperties": false
        },
        "outcome": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": ["untested", "not-applicable"]
            }
          },
          "required": ["status"],
          "additionalProperties": false
        }
      },
      "required": ["structural", "installation", "execution", "outcome"],
      "additionalProperties": false
    },
    "maintainers": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["project-maintainers"]
      }
    },
    "license": {
      "type": "string",
      "const": "MIT"
    }
  },
  "required": [
    "schema_version",
    "id",
    "title",
    "summary",
    "version",
    "category",
    "execution_mode",
    "difficulty",
    "risk_level",
    "estimated_duration",
    "tags",
    "inputs",
    "outputs",
    "prerequisites",
    "safety",
    "effects",
    "agent_requirements",
    "output_contract",
    "canonical",
    "agents",
    "verification",
    "maintainers",
    "license"
  ],
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "execution_mode": {
            "const": "autonomous"
          }
        },
        "required": ["execution_mode"]
      },
      "then": {
        "required": ["autonomy", "agent_requirements"],
        "properties": {
          "agent_requirements": {
            "type": "object",
            "required": ["capabilities"],
            "properties": {
              "capabilities": {
                "type": "array",
                "contains": {
                  "const": "persistent-execution"
                },
                "minContains": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "execution_mode": {
            "const": "supervised"
          }
        },
        "required": ["execution_mode"]
      },
      "then": {
        "not": {
          "required": ["autonomy"]
        }
      }
    }
  ],
  "$comment": "Field shape and the autonomous execution contract invariants are portable JSON Schema. Remaining cross-field recipe invariants require the Zod runtime validator."
}
