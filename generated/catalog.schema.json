{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "schema_version": {
        "type": "number",
        "const": 3
      },
      "id": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "title": {
        "type": "string",
        "minLength": 4,
        "maxLength": 100
      },
      "summary": {
        "type": "string",
        "minLength": 20,
        "maxLength": 240
      },
      "version": {
        "type": "string",
        "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*)?(?:\\+[0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*)?$"
      },
      "category": {
        "type": "string",
        "enum": [
          "api",
          "architecture",
          "code-review",
          "database",
          "debugging",
          "documentation",
          "maintenance",
          "migration",
          "operations",
          "performance",
          "refactoring",
          "release",
          "security",
          "testing"
        ]
      },
      "difficulty": {
        "type": "string",
        "enum": ["beginner", "intermediate", "advanced"]
      },
      "risk_level": {
        "type": "string",
        "enum": ["low", "medium", "high", "critical"]
      },
      "estimated_duration": {
        "type": "string",
        "pattern": "^[1-9]\\d*(?:m|h)$"
      },
      "tags": {
        "minItems": 1,
        "type": "array",
        "items": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        }
      },
      "inputs": {
        "type": "object",
        "properties": {
          "required": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "optional": {
            "minItems": 0,
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "required": ["required", "optional"],
        "additionalProperties": false
      },
      "outputs": {
        "minItems": 1,
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "prerequisites": {
        "minItems": 1,
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "safety": {
        "type": "object",
