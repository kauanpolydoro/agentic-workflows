          "destructive": {
            "type": "boolean"
          },
          "requires_human_approval": {
            "minItems": 0,
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "forbidden_actions": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "required": ["destructive", "requires_human_approval", "forbidden_actions"],
        "additionalProperties": false
      },
      "effects": {
        "type": "object",
        "properties": {
          "writes_code": {
            "type": "boolean"
          },
          "writes_configuration": {
            "type": "boolean"
          },
          "writes_documentation": {
            "type": "boolean"
          },
          "changes_dependencies": {
            "type": "boolean"
          },
          "changes_database": {
            "type": "boolean"
          },
          "changes_issue_tracker": {
            "type": "boolean"
          },
          "changes_production_traffic": {
            "type": "boolean"
          },
          "deletes_state": {
            "type": "boolean"
          },
          "publishes_artifacts": {
            "type": "boolean"
          }
        },
        "required": [
          "writes_code",
          "writes_configuration",
          "writes_documentation",
          "changes_dependencies",
          "changes_database",
          "changes_issue_tracker",
          "changes_production_traffic",
          "deletes_state",
          "publishes_artifacts"
